# Base de données (SQLite pour MVP)
DATABASE_URL=sqlite+aiosqlite:///./dlshub.db

# Redis (optionnel pour MVP)
# REDIS_URL=redis://localhost:6379

# Cloudinary (optionnel pour MVP)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Sécurité
SECRET_KEY=your_super_secret_key_here_change_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# API Tracker
TRACKER_API_URL=https://st.cf.api.ftpub.net/StatsTracker_Frontline
TRACKER_TIMEOUT=30
TRACKER_RETRY_ATTEMPTS=3

# Application
ENVIRONMENT=development
DEBUG=true
PROJECT_NAME=DLS Hub
VERSION=1.0.0
API_V1_STR=/api/v1

# CORS (format JSON pour Pydantic)
BACKEND_CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]

# Logging
LOG_LEVEL=INFO
LOG_FILE_PATH=logs/dls_hub.log

# Performance
MAX_UPLOAD_SIZE=10485760
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
